# ── Database (SQL Server) ────────────────────────────────────────────────────
DB_SERVER=Chaky\MSSQLSERVER01
DB_NAME=sms_intelix
# Set DB_TRUSTED=true for Windows Authentication (leave USER/PASSWORD empty)
DB_TRUSTED=false
DB_USER=sa
DB_PASSWORD=your_password_here
DB_POOL_SIZE=20

# ── Worker behaviour ─────────────────────────────────────────────────────────
# Seconds between DB polls when no campaigns are pending
WORKER_POLL_INTERVAL=5
# Max campaigns processed concurrently (scale with server CPU/RAM)
WORKER_MAX_CAMPAIGNS=3
# Max simultaneous HTTP requests to SMS providers (total, across all campaigns)
WORKER_HTTP_CONCURRENCY=20
# Rows fetched from DB per query (tune for memory vs round-trip balance)
WORKER_DB_BATCH_SIZE=500

# ── Laravel webhook ──────────────────────────────────────────────────────────
LARAVEL_BASE_URL=http://sms-intelix.test
# REQUIRED: generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must match CAMPAIGN_WEBHOOK_SECRET in sms-intelix .env
LARAVEL_WEBHOOK_SECRET=

# ── Directo SMS ──────────────────────────────────────────────────────────────
DIRECTO_BASE_URL=https://smsrp.directo.com/rest
# Preferred: Bearer token (set expiry date in the Directo portal)
DIRECTO_TOKEN=
# Fallback: username + password (from Directo "Conexión API" section)
DIRECTO_USERNAME=
DIRECTO_PASSWORD=

# ── Japifone (pending docs) ──────────────────────────────────────────────────
JAPIFONE_BASE_URL=
JAPIFONE_API_KEY=

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
